========== CONFIG ==========
data:
  features:
  - pmt_x
  - pmt_y
  - pmt_z
  - dom_time
  - charge
  percentiles_csv: null
  pulsemaps: features
  truth_all:
  - category2
  - totalEnergy
  - zenith
  - azimuth
  - pid
  - interaction_type
  truth_table: truth
experiment_name: exp004
flavors:
- Muon
- Electron
- Tau
- NC
geometry: full_geometry_emax1e6
mc: 340StringMC
model:
  add_global_variables_after_pooling: true
  add_norm_layer: false
  global_pooling_schemes:
  - min
  - max
  - mean
  - sum
  name: dynedge
  nb_neighbours: 8
  skip_readout: false
output:
  dirs:
    train: train_and_val
  root_dir: /project/def-nahee/kbas/Graphnet-Applications/Results
run:
  existing_output: error
slurm:
  account: def-nahee
  cpus_per_task: 8
  exclude: fc10713
  gpus_per_node: nvidia_h100_80gb_hbm3_3g.40gb:1
  mem: 64G
  time: '24:00:00'
task:
  class_names:
    0: tau_CC
    1: electron_CC_or_NC
    2: muon_CC
  labels:
  - 0
  - 1
  - 2
  mode: multiclass
  prediction_prefix: p_class
  target: category2
  type: classification
training:
  accumulate_grad_batches: 4
  base_lr: 1.0e-06
  batch_size: 512
  early_stopping_patience: 5
  max_epochs: 30
  multiprocessing_context: spawn
  num_workers: 8
  peak_lr: 0.0001
  pin_memory: true
  pretrained_weights: null
  seed: 20260202
  val_metrics_max_batches: null
  warmup_fraction: 0.5
weights:
  enabled: false
  loss_weight_column: null
  loss_weight_default_value: 1.0
  loss_weight_table: null


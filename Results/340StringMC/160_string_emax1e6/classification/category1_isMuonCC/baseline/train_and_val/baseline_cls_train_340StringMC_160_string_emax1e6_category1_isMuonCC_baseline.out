experiment_name: baseline
flavors:
- Muon
- Electron
- Tau
- NC
geometry: 160_string_emax1e6
mc: 340StringMC
model:
  add_global_variables_after_pooling: true
  add_norm_layer: false
  global_pooling_schemes:
  - min
  - max
  - mean
  - sum
  name: dynedge
  nb_neighbours: 8
  skip_readout: false
output:
  dirs:
    train: train_and_val
  root_dir: /project/def-nahee/kbas/Graphnet-Applications/Results
run:
  existing_output: error
slurm:
  account: def-nahee
  cpus_per_task: 8
  exclude: fc10713
  gpus_per_node: nvidia_h100_80gb_hbm3_3g.40gb:1
  mem: 96G
  time: '36:00:00'
task:
  class_names:
    0: not_muon_cc
    1: muon_cc
  labels:
  - 0
  - 1
  mode: binary
  prediction_prefix: p_class
  target: category1_isMuonCC
  type: classification
training:
  accumulate_grad_batches: 4
  base_lr: 1.0e-06
  batch_size: 256
  early_stopping_patience: 5
  max_epochs: 30
  multiprocessing_context: spawn
  num_workers: 8
  peak_lr: 0.0001
  pin_memory: true
  pretrained_weights: null

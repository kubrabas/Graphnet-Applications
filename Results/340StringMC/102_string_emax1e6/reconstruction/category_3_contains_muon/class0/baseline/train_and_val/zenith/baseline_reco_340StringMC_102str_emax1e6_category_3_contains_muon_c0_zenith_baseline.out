  - category2_tauCC_others_muonCC
  - category_3_contains_muon
  truth_table: truth
experiment_name: baseline
geometry: 102_string_emax1e6
mc: 340StringMC
model:
  add_global_variables_after_pooling: true
  add_norm_layer: false
  global_pooling_schemes:
  - min
  - max
  - mean
  - sum
  name: dynedge
  nb_neighbours: 8
  skip_readout: false
  transform_support:
  - 10.0
  - 100000000.0
output:
  dirs:
    train: train_and_val
  root_dir: /project/def-nahee/kbas/Graphnet-Applications/Results
routing:
  category: category_3_contains_muon
  classes: all
run:
  existing_output: error
slurm:
  account: def-nahee
  cpus_per_task: 8
  exclude: fc10713
  gpus_per_node: nvidia_h100_80gb_hbm3_3g.40gb:1
  mem: 64G
  time: '24:00:00'
slurm_overrides:
  azimuth: {}
  enabled: false
  energy: {}
  zenith: {}
target_overrides:
  azimuth:
    model: {}
    target_settings: {}
    training: {}
  enabled: false
  energy:
    model: {}
    target_settings: {}
    training: {}
  zenith:
    model: {}
    target_settings: {}
    training: {}
target_settings:
  azimuth:
    loss: von_mises_fisher_2d
    metrics: angle_deg
    prediction_labels:
    - azimuth_pred
    - azimuth_kappa
    target_labels:
    - azimuth
  energy:
    loss: log_cosh
    metrics: energy_log10
    prediction_labels:
    - log10_energy_pred
    target_labels:
    - totalEnergy
    transform_inference: pow10
    transform_target: log10
  zenith:
    loss: von_mises_fisher_2d
    metrics: angle_deg
    prediction_labels:
    - zenith_pred
    - zenith_kappa
    target_labels:
    - zenith
task:
  mode: separate
  targets:
  - energy
  - zenith
  - azimuth
  type: reconstruction
training:
  accumulate_grad_batches: 4
  base_lr: 1.0e-05
  batch_size: 256
  early_stopping_patience: 5
  max_epochs: 30
  multiprocessing_context: spawn
  num_workers: 8
  peak_lr: 0.002
  pin_memory: true
  pretrained_weights: null
  seed: 20260202
  val_metrics_max_batches: null
  warmup_fraction: 0.5
validation:
  write_plots: true
  write_predictions: true
  write_summary: true
weights:
  enabled: false
  loss_weight_column: event_weight
  loss_weight_default_value: 1.0
  loss_weight_table: truth


  - category_3_contains_muon
  truth_table: truth
experiment_name: baseline
geometry: 102_string_emax1e6
mc: 340StringMC
model:
  add_global_variables_after_pooling: true
  add_norm_layer: false
  global_pooling_schemes:
  - min
  - max
  - mean
  - sum
  name: dynedge
  nb_neighbours: 8
  skip_readout: false
  transform_support:
  - 10.0
  - 100000000.0
output:
  dirs:
    train: train_and_val

  base_lr: 1.0e-06
  batch_size: 512
  early_stopping_patience: 5
  max_epochs: 30
  multiprocessing_context: spawn
  num_workers: 8
  peak_lr: 0.0001
  pin_memory: true
  pretrained_weights: null
  seed: 20260202

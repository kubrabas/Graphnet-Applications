experiment_name: exp004
flavors:
- Muon
- Electron
- Tau
- NC
geometry: full_geometry_emax1e6
mc: 340StringMC
model:
  add_global_variables_after_pooling: true
  add_norm_layer: false
  global_pooling_schemes:
  - min
  - max
  - mean
  - sum
  name: dynedge
  nb_neighbours: 8
  skip_readout: false
output:
  dirs:
    train: train_and_val
  root_dir: /project/def-nahee/kbas/Graphnet-Applications/Results
task:
  class_names:
    0: tau_CC
    1: electron_CC_or_NC
    2: muon_CC
  labels:
  - 0
  - 1
  - 2
  mode: multiclass
  prediction_prefix: p_class
  target: category2
  type: classification
training:
